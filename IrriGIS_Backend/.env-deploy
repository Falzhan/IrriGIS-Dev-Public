# ================================================================================
# IrriGIS Backend - Deploy Environment Template
# ================================================================================
# Copy this file to .env and fill in your actual values for Render deployment.
# DO NOT commit real secrets — this file is kept in GitHub as a reference only.
# Render Secrets should be configured separately via the Render dashboard.
# ================================================================================

# Database (Supabase / Render)
DB_USER=postgres.lqhmeqjramkmzmyexnvk
DB_PASSWORD=<YOUR_DB_PASSWORD_HERE>
DB_NAME=postgres
DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
DB_PORT=5432

# JWT
JWT_SECRET=<YOUR_JWT_SECRET_HERE>
JWT_EXPIRES_IN=1d

# OAuth — load via Render Secrets, not hardcoded
GOOGLE_CLIENT_ID=<YOUR_GOOGLE_CLIENT_ID_HERE>
GOOGLE_CLIENT_SECRET=<YOUR_GOOGLE_CLIENT_SECRET_HERE>
FACEBOOK_APP_ID=<YOUR_FACEBOOK_APP_ID_HERE>
FACEBOOK_APP_SECRET=<YOUR_FACEBOOK_APP_SECRET_HERE>

# URLs
FRONTEND_URL=https://irrigis-backend.onrender.com
BACKEND_URL=https://irrigis-backend.onrender.com/api
